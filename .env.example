# --- Aplicación ---
APP_NAME=Fijazo API
# En true habilita /docs, /redoc y /openapi.json (filtran versión de FastAPI/API). Dejar
# en false en producción.
DEBUG=false
# Tamaño máximo (bytes) del body de una petición antes de responder 413.
MAX_REQUEST_BODY_BYTES=2097152

# --- CORS ---
# Orígenes del frontend autorizados, separados por comas.
# En producción: la URL del frontend en Vercel, p. ej. https://fijazo.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Opcional. Regex para orígenes dinámicos, útil para los preview deployments de Vercel.
# Ejemplo: ^https://fijazo-.*\.vercel\.app$
# CORS_ORIGIN_REGEX=

# --- MongoDB ---
# En local (sin Docker) usa localhost; con docker-compose usa mongodb://mongo:27017
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=fijazo
# Conexiones por instancia. En serverless el total contra Atlas es instancias × este valor.
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# --- Seguridad / JWT ---
# Genera un valor aleatorio en producción, p. ej.: openssl rand -hex 32
JWT_SECRET=change-me-in-production-please-use-a-secure-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Usuario administrador inicial (seed) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@fijazo.com
ADMIN_PASSWORD=changeme123

# --- Arranque ---
# Recalcula estadísticas y progresión de todos los usuarios al arrancar. Ponlo a false en
# Vercel: cada arranque en frío lo repetiría. Los endpoints ya recalculan por usuario.
RUN_STARTUP_BACKFILL=true
