# Puerto HTTP donde el gateway enruta los endpoints de usuarios.
HTTP_PORT=3001

# Transporte TCP de microservicio (contrato users.validate) para otros servicios.
TCP_HOST=0.0.0.0
TCP_PORT=3011

# Base de datos propia de este servicio (independiente del monolito).
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=users_service

# Hop B->C: auth-service para el estado de bloqueo dentro de users.validate.
AUTH_SERVICE_URL=http://localhost:8001
INTERNAL_API_KEY=change-me-internal-key
