# --- Aplicación ---
APP_NAME=Fijazo Progression Service
DEBUG=false

# --- MongoDB (base propia del servicio) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=progression_service
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Mensajería (consumer de eventos de apuesta) ---
RABBITMQ_URL=amqp://fijazo:fijazo@localhost:5672/
RECALC_QUEUE=progression.recalc
RECALC_PREFETCH=10
